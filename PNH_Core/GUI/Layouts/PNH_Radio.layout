FrameWidgetClass rootFrame {
 position 0 0
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass RadioWindow {
   visible 1
   clipchildren 1
   color 0 0 0 0.85
   position 0 0
   size 500 500
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 1
   vexactsize 1
   {
    TextWidgetClass Title {
     position 0 15
     size 1 40
     halign center_ref
     valign top_ref
     hexactpos 0
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "RÁDIO PNH TÁTICO"
     font "gui/fonts/etelkatextpro22"
     "text color" 1 0.5 0 1
     "text halign" center
     "text valign" center
    }

    // --- PAINEL DO VISOR DIGITAL ---
    PanelWidgetClass VisorPanel {
     color 0.05 0.15 0.05 0.9
     position 0 70
     size 450 120
     halign center_ref
     valign top_ref
     hexactpos 0
     vexactpos 1
     hexactsize 1
     vexactsize 1
     {
      TextWidgetClass TxtFreq {
       position 0 10
       size 430 30
       halign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       text "FREQ: 85.0 MHz"
       font "gui/fonts/etelkatextpro22"
       "text color" 0.2 1 0.2 1
      }
      TextWidgetClass TxtInfo {
       position 0 45
       size 430 25
       halign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       text "INFO: Aguardando Sinal..."
       font "gui/fonts/etelkatextpro16"
       "text color" 0.2 1 0.2 1
      }
      TextWidgetClass TxtStatus {
       position 0 75
       size 430 25
       halign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       text "ESTADO: DESLIGADO | VOL: 100%"
       font "gui/fonts/etelkatextpro16"
       "text color" 0.2 1 0.2 1
      }
     }
    }

    // --- BOTÕES DE SINTONIA ---
    TextWidgetClass LabelSintonia {
     position -90 220
     size 120 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "SINTONIA:"
     font "gui/fonts/etelkatextpro16"
     "text halign" right
     "text valign" center
    }
    ButtonWidgetClass BtnTuneDown {
     position 40 220
     size 60 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "<<<"
    }
    ButtonWidgetClass BtnTuneUp {
     position 110 220
     size 60 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text ">>>"
    }

    // --- BOTÕES DE VOLUME ---
    TextWidgetClass LabelVolume {
     position -90 270
     size 120 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "VOLUME:"
     font "gui/fonts/etelkatextpro16"
     "text halign" right
     "text valign" center
    }
    ButtonWidgetClass BtnVolDown {
     position 40 270
     size 60 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "-"
    }
    ButtonWidgetClass BtnVolUp {
     position 110 270
     size 60 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "+"
    }

    // --- BOTÕES DE AÇÃO ---
    ButtonWidgetClass BtnPower {
     position 0 340
     size 300 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "LIGAR / DESLIGAR RÁDIO"
    }
    ButtonWidgetClass BtnSOS {
     color 0.8 0 0 1
     position 0 390
     size 300 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "TRANSMITIR ALERTA SOS"
    }
    ButtonWidgetClass BtnClose {
     position 0 440
     size 300 40
     halign center_ref
     valign top_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "FECHAR JANELA"
    }
   }
  }
 }
}