FrameWidgetClass rootFrame {
 position 0 0
 size 1830 1080
 hexactpos 1
 vexactpos 1
 hexactsize 1
 vexactsize 1
 {
  ImageWidgetClass TabletFrame {
   ignorepointer 1
   position 0 0
   size 1830 1080
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   // CAMINHO ATUALIZADO PARA O NOSSO MOD
   imageTexture "PNH_Core\GUI\textures\tablet.edds"
   mode blend
   "src alpha" 1
   "clamp mode" clamp
   "stretch mode" fit_w_center
   {
    // --- CONTAINER DA TELA (Área útil do LCD) ---
    PanelWidgetClass ScreenContent {
     ignorepointer 0
     position 369.805 256.002
     size 1105.72 572.498
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     {
      // APP 1: HOME (Inicia Visível)
      PanelWidgetClass PanelHome {
       visible 1
       size 1 1
       {
        TextWidgetClass TxtHome {
         size 1 40
         halign center_ref
         valign center_ref
         text "SISTEMA OPERACIONAL PNH"
         font "gui/fonts/etelkatextpro22"
         "text color" 0.2 1 0.2 1
         "text halign" center
        }
       }
      }

      // APP 2: MAPA (GPS)
      PanelWidgetClass PanelMap {
       visible 0
       size 1 1
       {
        MapWidgetClass TabletMap {
         size 1 1
         hexactpos 1
         vexactpos 1
         hexactsize 1
         vexactsize 1
        }
       }
      }

      // APP 3: RÁDIO PNH
      PanelWidgetClass PanelRadio {
       visible 0
       size 1 1
       {
        // Aqui inseriremos o design de rádio que já validamos
       }
      }
     }
    }
   }
  }

  // --- MOLDURA DE BOTÕES (As teclas F1, F2...) ---
  FrameWidgetClass buttonFrame {
   ignorepointer 0
   position 397.736 837.704
   size 576.568 48
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   {
    ButtonWidgetClass BtnF1 { // Mapeado sobre 'zoomin'
     position 31.22 1.83
     size 79.22 46.16
     style Empty
     text "HOME"
    }
    ButtonWidgetClass BtnF2 { // Mapeado sobre 'zoomout'
     position 148.77 1.83
     size 79.22 46.16
     style Empty
     text "MAPA"
    }
    ButtonWidgetClass BtnF3 { // Mapeado sobre 'options'
     position 262.65 1.83
     size 79.22 46.16
     style Empty
     text "RADIO"
    }
    ButtonWidgetClass BtnF4 { // Mapeado sobre 'back'
     position 371.02 1.83
     size 79.22 46.16
     style Empty
     text "SOS"
    }
    ButtonWidgetClass BtnPower { // Mapeado sobre 'power'
     position 477.55 1.83
     size 79.22 46.16
     style Empty
    }
   }
  }
 }
}