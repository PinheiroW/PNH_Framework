FrameWidgetClass rootFrame {
 position 0 0
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  WindowWidgetClass RadioWindow {
   visible 1
   clipchildren 1
   color 0.1 0.1 0.1 0.95
   position 0 0
   size 400 300
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 1
   vexactsize 1
   style DayZDefaultPanel
   {
    TextWidgetClass Title {
     position 0 15
     size 1 30
     halign center_ref
     valign top_ref
     hexactpos 0
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "RÁDIO PNH"
     font "gui/fonts/etelkatextpro22"
     "text color" 1 0.5 0 1
     "text halign" center
    }
    
    // BOTÃO MUTE (Original)
    ButtonWidgetClass BtnMute {
     color 0.3 0.3 0.3 1
     position 0 -30
     size 200 40
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 1
     hexactsize 1
     vexactsize 1
     style DayZDefaultButton
     text "LIGAR / DESLIGAR"
     font "gui/fonts/etelkatextpro16"
    }

    // NOVO BOTÃO FECHAR
    ButtonWidgetClass BtnClose {
     color 0.6 0 0 1
     position 0 30
     size 200 40
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 1
     hexactsize 1
     vexactsize 1
     style DayZDefaultButton
     text "FECHAR JANELA"
     font "gui/fonts/etelkatextpro16"
    }

    TextWidgetClass Footer {
     position 0 10
     size 1 20
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Sistema PNH Core 2.0"
     "text halign" center
     "text color" 0.5 0.5 0.5 0.5
    }
   }
  }
 }
}